# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Drive integration for Film Journal
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/film/integrations/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=32-byte-base64-or-hex-secret

# Optional build metadata (used for the Settings version footer)
# GIT_COMMIT_SHA=your-commit-sha
# BUILD_TIME=2026-03-16T00:00:00.000Z
